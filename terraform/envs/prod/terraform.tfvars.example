aws_region = "eu-west-1"

amplify_web_url = "https://gabag-operations-platform.example.com"
domain_name     = "gabag-operations-platform.example.com"

create_dns_zone              = false
enable_amplify_custom_domain = false

db_name     = "gabag_operations_platform_prod"
# db_password provided via TF_VAR_db_password from secrets, same as shared

# Secrets (provided via TF_VAR_* in CI; do not commit)
# auth_secret          = "..."
# cron_secret          = "..."
# s3_access_key_id     = "..."
# s3_secret_access_key = "..."

github_repository       = "https://github.com/nishadincresco/gabag-operations-platform"
github_actions_username = "github-actions-user"
manage_amplify_git      = false

amplify_sync_branches = ["main"]
