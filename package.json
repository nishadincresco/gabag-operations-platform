{
  "name": "gabag-operations-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "turbo run db:migrate",
    "db:migrate:deploy": "turbo run db:migrate:deploy",
    "db:migrate:deploy:prod": "turbo run db:migrate:deploy:prod --filter=@repo/db",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "db:generate": "turbo run db:generate"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.15.3",
    "prettier": "^3.7.4",
    "prisma": "^7.7.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "next-auth": "^5.0.0-beta.31"
  }
}
