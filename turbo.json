{
  "$schema": "https://turbo.build/schema.json",

  "ui": "tui",

  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "AUTH_SECRET",
    "NEXTAUTH_SECRET",
    "AUTH_TRUST_HOST",
    "ALLOW_LOCAL_UPLOADS",
    "npm_package_version",
    "NEXTAUTH_URL",
    "NODE_ENV",
    "NEXT_PUBLIC_APP_URL",
    "CRON_SECRET",
    "SEED_ADMIN_EMAIL",
    "SEED_ADMIN_PASSWORD",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_REGION",
    "S3_BUCKET_NAME",
    "S3_PUBLIC_URL",
    "AWS_REGION"
  ],

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },

    "lint": {
      "dependsOn": ["^lint"]
    },

    "check-types": {
      "dependsOn": ["^build", "^check-types", "^db:generate"]
    },

    "db:generate": {
      "cache": false,
      "env": ["DATABASE_URL", "DIRECT_URL"]
    },

    "db:migrate": {
      "cache": false
    },

    "db:migrate:deploy": {
      "cache": false
    },

    "db:migrate:deploy:prod": {
      "cache": false
    },

    "db:push": {
      "cache": false
    },

    "db:seed": {
      "cache": false
    },

    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
