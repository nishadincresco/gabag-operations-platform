{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "bun x prisma generate",
    "db:push": "bun --env-file=../../.env x prisma db push",
    "db:migrate": "bun --env-file=../../.env x prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy:prod": "prisma migrate deploy",
    "db:studio": "bun --env-file=../../.env x prisma studio",
    "db:seed": "bun --env-file=../../.env src/seed.ts",
    "build": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "bcryptjs": "3.0.3",
    "pg": "^8.13.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "5.9.2"
  },
  "prisma": {
    "seed": "bun run src/seed.ts"
  }
}
