# ── Database (pointed at shared RDS, per-env logical DB) ───────────────────
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/gabag_operations_platform_dev?sslmode=no-verify"
DIRECT_URL="postgresql://postgres:CHANGE_ME@localhost:5432/gabag_operations_platform_dev?sslmode=no-verify"

# ── NextAuth v5 ────────────────────────────────────────────────────────────
AUTH_SECRET=                 # openssl rand -base64 32
NEXTAUTH_SECRET=             # same value as AUTH_SECRET
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AWS S3 ─────────────────────────────────────────────────────────────────
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=eu-west-1
S3_BUCKET_NAME=
S3_PUBLIC_URL=
AWS_REGION=eu-west-1

# ── Cron / EventBridge ─────────────────────────────────────────────────────
CRON_SECRET=

# ── Seeding ────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# ── GitHub Actions secrets required (Settings → Secrets → Actions) ─────────
# DATABASE_URL      → dev  RDS connection string (postgresql://postgres:DB_PASSWORD@RDS_ENDPOINT/gabag_operations_platform_dev)
# PROD_DATABASE_URL → prod RDS connection string (postgresql://postgres:DB_PASSWORD@RDS_ENDPOINT/gabag_operations_platform_prod)
# DB_PASSWORD       → RDS master password (for Terraform)
# AUTH_SECRET       → same secure string as above
# CRON_SECRET       → same secure string as above
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY → AWS IAM keys
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY → AWS IAM keys (for Terraform CI)
